# Railway MySQL (use external host for local dev, internal for Railway deploy)
MYSQL_HOST=caboose.proxy.rlwy.net
MYSQL_PORT=18766
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DB=railway

# Telegram (optional for market_data, required for main bot)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# TradingView webhook secret (optional)
TV_WEBHOOK_SECRET=
